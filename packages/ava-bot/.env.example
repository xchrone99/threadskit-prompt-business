# Telegram Bot Token dari @BotFather
TELEGRAM_BOT_TOKEN=isi_token_disini

# OpenRouter API Key (pakai key yang udah ada dari project ai-threads-content-engine)
OPENROUTER_API_KEY=sk-or-isi_disini

# OpenRouter Base URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Xendit API Key (isi nanti setelah daftar)
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# Admin / CEO Telegram User ID
CEO_TELEGRAM_ID=isi_id_telegram_kamu

# Default model untuk Entry tier (free tier OpenRouter)
FREE_MODEL=openrouter/free

# Premium model untuk Pro tier
PREMIUM_MODEL=google/gemini-2.5-pro
